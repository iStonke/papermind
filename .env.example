COMPOSE_PROJECT_NAME=papermind

FRONTEND_PORT=5179
BACKEND_PORT=8040
DB_PORT=5440
AI_PORT=11439

POSTGRES_DB=<your_db_name>
POSTGRES_USER=<your_db_user>
POSTGRES_PASSWORD=<your_db_password>

DATABASE_URL=postgresql://<your_db_user>:<your_db_password>@db:5432/<your_db_name>
AI_BASE_URL=http://ai:11439
VITE_API_BASE_URL=http://localhost:8040
STORAGE_PATH=/data/storage
PUBLIC_WEB_BASE_URL=
UPLOAD_MAX_BYTES=26214400
MOBILE_UPLOAD_SESSION_TTL_MINUTES=15
MOBILE_UPLOAD_DEFAULT_MAX_FILES=20
MOBILE_UPLOAD_MAX_FILES_LIMIT=50
CORS_ALLOW_ORIGINS=http://localhost:5179,http://127.0.0.1:5179
AUTO_OCR_ON_UPLOAD=true
MIN_TEXT_CHARS=300
TEXT_CHECK_PAGES=2
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_OCR_TIMEOUT_SECONDS=900
SEARCH_QUERY_MAX_LENGTH=256
FTS_LANGUAGE=german
INDEX_AUTO_ON_READY=true
EMBED_MODEL=hash-384-v1
EMBED_DIM=384
EMBED_BATCH_SIZE=32
EMBED_MAX_TEXTS=64
EMBED_MAX_CHARS=4000
CHUNK_SIZE_CHARS=1000
CHUNK_OVERLAP_CHARS=100
AI_EMBED_TIMEOUT_SECONDS=30
RETRIEVAL_MAX_TOP_K=20

VITE_HMR_HOST=localhost
VITE_HMR_PORT=5179
VITE_HMR_PROTOCOL=ws
