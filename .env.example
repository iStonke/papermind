COMPOSE_PROJECT_NAME=papermind

FRONTEND_PORT=5179
BACKEND_PORT=8040
DB_PORT=5440
AI_PORT=11439

POSTGRES_DB=<your_db_name>
POSTGRES_USER=<your_db_user>
POSTGRES_PASSWORD=<your_db_password>

DATABASE_URL=postgresql://<your_db_user>:<your_db_password>@db:5432/<your_db_name>

# Nicht-privilegierte Rolle für Web-Requests (Row-Level Security / Daten-Isolation).
# Migration 042 legt die Rolle "papermind_app" mit APP_DB_PASSWORD an.
APP_DB_PASSWORD=<your_app_db_password>
APP_DATABASE_URL=postgresql://papermind_app:<your_app_db_password>@db:5432/<your_db_name>

# Worker-Rolle (NOSUPERUSER + BYPASSRLS) für Hintergrundjobs. Migration 043 legt
# die Rolle "papermind_worker" an. Leer = Worker läuft als Superuser (Fallback).
WORKER_DB_PASSWORD=<your_worker_db_password>
WORKER_DATABASE_URL=postgresql://papermind_worker:<your_worker_db_password>@db:5432/<your_db_name>
AI_BASE_URL=http://ai:11439

# ── Heimnetz / Raspberry Pi ──────────────────────────────────────────────────
# PI_IP: die feste IP-Adresse deines Raspberry Pi im Heimnetz, z.B. 192.168.1.42
# Diese Adresse trägst du einmal in den Router ein (DHCP-Reservierung empfohlen).
# Alle drei folgenden Einträge müssen dieselbe IP verwenden.

# URL, die vom Browser erreichbar sein muss:
PUBLIC_WEB_BASE_URL=http://<PI_IP>:8040

# Wohin das Vue-Frontend seine API-Requests schickt (wird im Browser ausgeführt):
VITE_API_BASE_URL=http://<PI_IP>:8040

# Erlaubte CORS-Origins – Frontend-URL + direkter Pi-Zugriff:
CORS_ALLOW_ORIGINS=http://<PI_IP>:5179,http://localhost:5179,http://127.0.0.1:5179

# ── iOS Shortcut Direct Upload ────────────────────────────────────────────────
# Statischer API-Key für den /api/direct-upload Endpoint.
# Generiere einen sicheren Wert, z.B. mit: openssl rand -hex 32
# Diesen Key trägst du einmalig im iOS Shortcut ein.
DIRECT_UPLOAD_API_KEY=<generate_with_openssl_rand_hex_32>

# ─────────────────────────────────────────────────────────────────────────────
# Authentifizierung (Login fürs Web-UI)
# AUTH_ENABLED=false schaltet die gesamte Auth ab (NICHT für den Produktivbetrieb).
AUTH_ENABLED=true
# Signaturschlüssel für Access-Tokens — MUSS gesetzt sein, sonst werden Tokens
# bei jedem Backend-Neustart ungültig. Erzeugen mit: openssl rand -hex 32
AUTH_SECRET_KEY=<generate_with_openssl_rand_hex_32>
# Gültigkeitsdauer eines Logins in Sekunden (Standard: 24h).
AUTH_TOKEN_TTL_SECONDS=86400
# Erst-Admin: wird NUR beim ersten Start angelegt, solange noch kein Benutzer
# existiert. Danach Benutzer über das Web-UI (Konto → Benutzerverwaltung) verwalten.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=<choose_a_strong_password>

# ─────────────────────────────────────────────────────────────────────────────
STORAGE_PATH=/data/storage
UPLOAD_MAX_BYTES=26214400
AUTO_OCR_ON_UPLOAD=true
MIN_TEXT_CHARS=300
TEXT_CHECK_PAGES=2
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_OCR_TIMEOUT_SECONDS=900
IMPORT_INBOX_DROP_PATH=/scan-inbox
IMPORT_INBOX_FILE_STABLE_SECONDS=3
SEARCH_QUERY_MAX_LENGTH=256
FTS_LANGUAGE=german
INDEX_AUTO_ON_READY=true
EMBED_MODEL=hash-384-v1
EMBED_DIM=384
EMBED_BATCH_SIZE=32
EMBED_MAX_TEXTS=64
EMBED_MAX_CHARS=4000
CHUNK_SIZE_CHARS=1000
CHUNK_OVERLAP_CHARS=100
AI_EMBED_TIMEOUT_SECONDS=30
RETRIEVAL_MAX_TOP_K=20

VITE_HMR_HOST=localhost
VITE_HMR_PORT=5179
VITE_HMR_PROTOCOL=ws
