COMPOSE_PROJECT_NAME=papermind

# Public entrypoint. In production only this port is published by Compose.
FRONTEND_PORT=5179

POSTGRES_DB=<your_db_name>
POSTGRES_USER=<your_db_user>
POSTGRES_PASSWORD=<your_strong_db_password>
DATABASE_URL=postgresql://<your_db_user>:<your_strong_db_password>@db:5432/<your_db_name>

# Nicht-privilegierte Rolle für Web-Requests (Row-Level Security / Daten-Isolation).
# Migration 042 legt die Rolle "papermind_app" mit APP_DB_PASSWORD an.
APP_DB_PASSWORD=<your_strong_app_db_password>
APP_DATABASE_URL=postgresql://papermind_app:<your_strong_app_db_password>@db:5432/<your_db_name>

# Worker-Rolle (NOSUPERUSER + BYPASSRLS) für Hintergrundjobs. Migration 043 legt
# die Rolle "papermind_worker" an. Leer = Worker läuft als Superuser (Fallback).
WORKER_DB_PASSWORD=<your_strong_worker_db_password>
WORKER_DATABASE_URL=postgresql://papermind_worker:<your_strong_worker_db_password>@db:5432/<your_db_name>

# Same-origin API via the production frontend/Nginx proxy.
VITE_API_BASE_URL=
PUBLIC_WEB_BASE_URL=http://<PI_IP>:5179
CORS_ALLOW_ORIGINS=http://<PI_IP>:5179

# Generate with: openssl rand -hex 32
DIRECT_UPLOAD_API_KEY=<generate_with_openssl_rand_hex_32>

# Authentication (web UI login)
AUTH_ENABLED=true
# REQUIRED in production. Generate with: openssl rand -hex 32
AUTH_SECRET_KEY=<generate_with_openssl_rand_hex_32>
AUTH_TOKEN_TTL_SECONDS=86400
# First admin — created only on first start while the users table is empty.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=<choose_a_strong_password>

STORAGE_PATH=/data/storage
UPLOAD_MAX_BYTES=26214400
AUTO_OCR_ON_UPLOAD=true
MIN_TEXT_CHARS=300
TEXT_CHECK_PAGES=2
WORKER_POLL_INTERVAL_SECONDS=3
WORKER_OCR_TIMEOUT_SECONDS=900
# OCR-Drosselung (Pi): parallele Seiten je Dokument + 1 Thread je Seite,
# damit OCR nicht alle Kerne auslastet (Hitze/Lüfter) und DB/API nicht ausbremst.
OCR_JOBS=3
OMP_THREAD_LIMIT=1
IMPORT_INBOX_DROP_PATH=/scan-inbox
IMPORT_INBOX_FILE_STABLE_SECONDS=3
SEARCH_QUERY_MAX_LENGTH=256
FTS_LANGUAGE=german
INDEX_AUTO_ON_READY=true
# Embeddings via Ollama (bge-m3, 1024 Dim). Auf dem Pi: ollama pull bge-m3
EMBED_MODEL=bge-m3
EMBED_DIM=1024
EMBED_BATCH_SIZE=32
EMBED_MAX_TEXTS=64
EMBED_MAX_CHARS=4000
CHUNK_SIZE_CHARS=1000
CHUNK_OVERLAP_CHARS=100
AI_EMBED_TIMEOUT_SECONDS=30
AI_CHAT_TIMEOUT_SECONDS=60
RETRIEVAL_MAX_TOP_K=20
DEDUPE_CANDIDATE_LIMIT=200
DEDUPE_TEXT_DISTANCE_THRESHOLD=6

# System-/Hardware-Status (Bereich "System" in den Einstellungen).
# Geteiltes Verzeichnis für Power-Aktionen (Herunterfahren/Neustarten).
# Muss mit dem Host-Helfer übereinstimmen (siehe deploy/host-control/README.md).
# Standard ist ./host-control relativ zum Compose-Verzeichnis.
HOST_CONTROL_DIR=./host-control
